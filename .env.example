# ---- Site ----
# Public URL of the deployed site (no trailing slash). Used in emails and Stripe redirects.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Random 32+ char secret used to sign session cookies. Generate: openssl rand -hex 32
SESSION_SECRET=

# Comma-separated list of emails allowed into the admin panel.
ADMIN_EMAILS=you@example.com

# ---- Supabase (Postgres + Storage) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_live_...
# From the Stripe webhook endpoint you create for /api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# ---- Mux (all video: music videos + paywalled film) ----
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
# Signing key pair for signed (paywalled) playback. Create under Mux > Settings > Signing Keys.
MUX_SIGNING_KEY_ID=
# The private key, base64 encoded exactly as Mux hands it to you.
MUX_SIGNING_KEY_PRIVATE=

# ---- Resend (magic link + purchase emails) ----
RESEND_API_KEY=
EMAIL_FROM="BLakHarts <signal@yourdomain.com>"
